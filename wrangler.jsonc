{
  "name": "listing-intake-portal",
  "main": "src/index.ts",
  "compatibility_date": "2024-09-01",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "listing-intake-db",
      "database_id": "<your-database-id>"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "LISTING_INTAKE_DO",
        "class_name": "ListingIntakeDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["ListingIntakeDO"]
    }
  ],
  "r2_buckets": [
    {
      "binding": "DOCUMENTS_BUCKET",
      "bucket_name": "listing-intake-documents"
    }
  ],
  "queues": {
    "producers": [
      {
        "binding": "INTAKE_QUEUE",
        "queue": "intake-events"
      }
    ]
  }
}
